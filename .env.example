# Phase B - Telegram Drama Bot
NODE_ENV=development
PORT=3000
DATABASE_PATH=./db/drama.db

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
TELEGRAM_BOT_API_URL=http://localhost:8081
BOT_POLLING=true

# Telegram Bot API (self-hosted)
TELEGRAM_BOT_API_WEBHOOK_URL=https://your-domain/api/bot/webhook

# JWT
JWT_SECRET=change-this-to-random-strong-key

# NOWPayments
NOWPAYMENTS_API_KEY=your-nowpayments-api-key
NOWPAYMENTS_IPN_SECRET=your-nowpayments-ipn-secret

# Application URLs
APP_URL=https://your-domain.com
WEBHOOK_URL=https://your-domain.com/api/payment/webhook

# Logging
LOG_LEVEL=debug

# VIP Tier Prices
VIP_PREMIUM_PRICE=9.99
VIP_PLUS_PRICE=24.99

# Referral
REFERRAL_COMMISSION=1.00

# Video Processing
FFMPEG_PATH=ffmpeg
FFMPEG_TIMEOUT=300000
TEMP_DIR=./uploads/temp
OUTPUT_DIR=./uploads/merged
